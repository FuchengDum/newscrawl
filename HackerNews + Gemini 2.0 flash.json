    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\n// 设置最大允许字符数，12000字大约消耗 4k-6k Tokens，比较安全且经济\nconst MAX_LENGTH = 12000; \n\nfor (const item of $input.all()) {\n  let content = item.json.text || \"\";\n\n  if (content.length > MAX_LENGTH) {\n    // 截断文本并添加提示，让 AI 知道内容不完整\n    item.json.text = content.substring(0, MAX_LENGTH) + \"\\n\\n[...Content truncated due to length limits...]\";\n    item.json.is_truncated = true; // 标记一下，方便后续排查\n  } else {\n    item.json.is_truncated = false;\n  }\n}\n\nreturn $input.all();"
      },
